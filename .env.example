DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
SERVER_PORT=8080
JWT_SECRET=your_256_bit_secret_key_change_me_in_production
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Account Lifecycle Configuration
ACCOUNT_FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MINUTES=60
EMAIL_VERIFICATION_LEGACY_USERS_EXEMPT=true
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30

# Transactional Email Configuration (disabled by default; use test credentials only)
EMAIL_ENABLED=false
EMAIL_MODE=fake
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_START_TLS=true

# Authentication Abuse Protection
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_HASH_SECRET=dev_rate_limit_secret_change_me
AUTH_RATE_LIMIT_REGISTER_LIMIT=20
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
AUTH_RATE_LIMIT_LOGIN_LIMIT=30
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_REFRESH_LIMIT=60
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_RESEND_VERIFICATION_LIMIT=5
AUTH_RATE_LIMIT_RESEND_VERIFICATION_WINDOW_SECONDS=3600
AUTH_RATE_LIMIT_FORGOT_PASSWORD_LIMIT=5
AUTH_RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=3600
AUTH_RATE_LIMIT_RESET_PASSWORD_LIMIT=10
AUTH_RATE_LIMIT_RESET_PASSWORD_WINDOW_SECONDS=900

# Admin Bootstrap (Opt-in for local development, disabled by default)
# ADMIN_BOOTSTRAP_ENABLED=true
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your_secure_admin_password

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Storage Configuration (local or s3)
STORAGE_TYPE=local

# Local Storage Configuration (Used when STORAGE_TYPE=local)
UPLOAD_DIR=/app/uploads
UPLOAD_BASE_URL=http://localhost:8080/api/images/

# S3-Compatible Durable Object Storage (Used when STORAGE_TYPE=s3)
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET_NAME=my-bucket
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_PUBLIC_URL_PREFIX=https://cdn.example.com/
S3_PATH_STYLE_ACCESS=false

# Local-to-S3 Image Migration Utility
MIGRATION_LOCAL_TO_S3_ENABLED=false
MIGRATION_LOCAL_TO_S3_CONFIRM=false
MIGRATION_LOCAL_TO_S3_DRY_RUN=true
MIGRATION_LOCAL_TO_S3_REPORT_PATH=migration-report.json

# Stripe Payment Gateway Configuration
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_CURRENCY=USD
STRIPE_REDIRECT_BASE_URL=http://localhost:5173
STRIPE_SESSION_TIMEOUT_SECONDS=1800

# Frontend Stripe Checkout is configured separately in frontend/.env.example:
# VITE_STRIPE_CHECKOUT_ENABLED=false
