# ==============================================================================
# STAGING ENVIRONMENT TEMPLATE (.env.staging.example)
# ==============================================================================
#
# This file serves as a template for staging environment configuration.
# Do NOT commit actual secrets, keys, passwords, or certificates to the repository.
# Rename this file to '.env.staging' and populate it with actual values.
#
# ------------------------------------------------------------------------------
# SECURITY NOTE ON PROXY TRUST:
# When deploying in the Compose staging topology, the backend container is isolated 
# within the internal network and is not directly exposed to the host or internet.
# Only Nginx is exposed.
#
# Under this controlled environment, 'app.auth-rate-limit.trust-forwarded-for=true'
# must be enabled (via AUTH_RATE_LIMIT_TRUST_FORWARDED_FOR=true) so the backend 
# can extract the real client IP passed by Nginx in the X-Forwarded-For header.
#
# Direct exposure of the backend to public ports invalidates this trust model and 
# permits rate-limiting bypass via spoofed client headers.
# ------------------------------------------------------------------------------

# 1. DATABASE CONFIGURATION (Backend-only secrets)
# Staging database access credentials.
DB_HOST=postgres-staging
DB_PORT=5432
DB_NAME=ecommerce_staging_db
DB_USERNAME=postgres_staging_user
DB_PASSWORD=change_me_to_a_secure_staging_password_12345

# 2. SERVER & JWT AUTH CONFIGURATION (Backend-only secrets)
SERVER_PORT=8080
# Must be a secure 256-bit (at least 32-character) secret key. Do not use production keys here.
JWT_SECRET=change_me_to_a_secure_staging_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# 3. ACCOUNT LIFECYCLE & VERIFICATION CONFIGURATION (Backend-only non-secrets)
# Base URL where the frontend is publicly reachable.
ACCOUNT_FRONTEND_BASE_URL=https://staging.example.com
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MINUTES=60
EMAIL_VERIFICATION_LEGACY_USERS_EXEMPT=true
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30

# 4. TRANSACTIONAL EMAIL CONFIGURATION (SMTP) (Backend-only secrets)
# Keep disabled unless explicitly authorized by the project owner.
EMAIL_ENABLED=false
EMAIL_MODE=fake
EMAIL_FROM_ADDRESS=noreply@staging.example.com
EMAIL_SMTP_HOST=smtp.staging.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=staging_smtp_user
EMAIL_SMTP_PASSWORD=change_me_to_staging_smtp_password
EMAIL_SMTP_START_TLS=true

# 5. AUTHENTICATION ABUSE PROTECTION (Backend-only)
AUTH_RATE_LIMIT_ENABLED=true
# Must be a secure custom value in staging to pass the validation check.
AUTH_RATE_LIMIT_HASH_SECRET=change_me_to_a_secure_staging_rate_limit_hash_secret_value
# Enabled because Nginx handles public edge traffic, strips incoming forwarding headers, and overrides X-Forwarded-For.
AUTH_RATE_LIMIT_TRUST_FORWARDED_FOR=true

# Staging rate limiting thresholds
AUTH_RATE_LIMIT_REGISTER_LIMIT=20
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
AUTH_RATE_LIMIT_LOGIN_LIMIT=30
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_REFRESH_LIMIT=60
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_RESEND_VERIFICATION_LIMIT=5
AUTH_RATE_LIMIT_RESEND_VERIFICATION_WINDOW_SECONDS=3600
AUTH_RATE_LIMIT_FORGOT_PASSWORD_LIMIT=5
AUTH_RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=3600
AUTH_RATE_LIMIT_RESET_PASSWORD_LIMIT=10
AUTH_RATE_LIMIT_RESET_PASSWORD_WINDOW_SECONDS=900

# 6. METRICS SCRAPE SECURITY (Backend-only secrets)
# Must be at least 16 characters in staging to pass production-like validation checks.
METRICS_SECURITY_TOKEN=change_me_to_a_secure_staging_metrics_scraping_token_at_least_16_chars

# 7. CORS CONFIGURATION (Backend-only non-secrets)
# Allowed origins for API requests. Must match the public address of the Nginx server.
# Cannot contain 'localhost' or '127.0.0.1' under the production profile.
CORS_ALLOWED_ORIGINS=https://staging.example.com

# 8. STORAGE CONFIGURATION (Backend-only secrets)
# Supported values: local, s3
STORAGE_TYPE=local
UPLOAD_DIR=/app/uploads
UPLOAD_BASE_URL=https://staging.example.com/api/images/

# S3-compatible cloud storage settings (Disabled by default)
# Do not enable or populate unless authorized by the owner.
S3_ENDPOINT=https://staging.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET_NAME=staging-bucket
S3_ACCESS_KEY=change_me_to_staging_s3_access_key
S3_SECRET_KEY=change_me_to_staging_s3_secret_key
S3_PUBLIC_URL_PREFIX=https://staging-cdn.example.com/
S3_PATH_STYLE_ACCESS=false

# 9. LOCAL-TO-S3 IMAGE MIGRATION UTILITY (Backend-only non-secrets)
# MUST remain disabled unless under controlled migration scenarios.
MIGRATION_LOCAL_TO_S3_ENABLED=false
MIGRATION_LOCAL_TO_S3_CONFIRM=false
MIGRATION_LOCAL_TO_S3_DRY_RUN=true
MIGRATION_LOCAL_TO_S3_REPORT_PATH=migration-report.json

# 10. STRIPE PAYMENT GATEWAY CONFIGURATION (Backend-only secrets)
# Keep disabled unless explicitly authorized by the project owner.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=change_me_to_staging_stripe_secret_key
STRIPE_WEBHOOK_SECRET=change_me_to_staging_stripe_webhook_secret
STRIPE_CURRENCY=USD
STRIPE_REDIRECT_BASE_URL=https://staging.example.com
STRIPE_SESSION_TIMEOUT_SECONDS=1800

# 11. FRONTEND BUILD CONFIGURATION (Vite build-time non-secrets)
# Used during the frontend docker build stage. These are compiled directly into frontend assets.
VITE_API_BASE_URL=/api
VITE_STRIPE_CHECKOUT_ENABLED=false
